rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isPatient(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data.role == 'patient';
    }

    function isDoctor() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'doctor';
    }

    function sharingEnabled(patientId) {
      return get(/databases/$(database)/documents/users/$(patientId)).data.isSharingEnabled == true;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Users collection
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
    }

    // Records collection
    match /records/{recordId} {
      allow create: if isSignedIn() && request.resource.data.patientId == request.auth.uid;
      allow read: if isOwner(resource.data.patientId) || (isDoctor() && sharingEnabled(resource.data.patientId));
      allow delete: if isOwner(resource.data.patientId);
    }

    // Reminders collection
    match /reminders/{reminderId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
  }
}
