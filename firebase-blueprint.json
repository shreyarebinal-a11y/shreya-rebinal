{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile for patients or doctors",
      "type": "object",
      "properties": {
        "role": { "type": "string", "enum": ["patient", "doctor"] },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "age": { "type": "number" },
        "gender": { "type": "string" },
        "bloodGroup": { "type": "string" },
        "address": { "type": "string" },
        "degree": { "type": "string" },
        "isSharingEnabled": { "type": "boolean" }
      },
      "required": ["role", "name", "email"]
    },
    "MedicalRecord": {
      "title": "Medical Record",
      "description": "A prescription or medical report",
      "type": "object",
      "properties": {
        "patientId": { "type": "string" },
        "fileURL": { "type": "string" },
        "fileName": { "type": "string" },
        "type": { "type": "string", "enum": ["prescription", "report"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["patientId", "fileURL", "type", "createdAt"]
    },
    "Reminder": {
      "title": "Reminder",
      "description": "Health reminders for patients",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "time": { "type": "string" },
        "days": { "type": "array" },
        "active": { "type": "boolean" },
        "type": { "type": "string", "enum": ["medicine", "appointment", "checkup"] }
      },
      "required": ["userId", "title", "time", "active"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "records/{recordId}": {
      "schema": "MedicalRecord",
      "description": "Medical record documents"
    },
    "reminders/{reminderId}": {
      "schema": "Reminder",
      "description": "Health reminders"
    }
  }
}
